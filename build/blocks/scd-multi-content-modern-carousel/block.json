{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "scdkpi/scdkpi-multi-content-modern-carousel",
  "version": "0.1.0",
  "title": "SCD Multi-Content Modern Carousel",
  "category": "scdkpi-story-craft-digital",
  "icon": "email",
  "description": "A premium, ultra-responsive content slider that delivers a sleek, high-end browsing experience. Features immersive 'zoom-on-hover' visuals, smart gradient overlays for text clarity, and a real-time progress tracker. Every detail—from text size to corner curves—automatically recalibrates to ensure a flawless look on every screen size.",
  "keywords": [
    "details",
    "project",
    "modern",
    "process",
    "content",
    "scd",
    "slide"
  ],
  "supports": {
    "html": false,
    "multiple": true
  },
  "example": {},
  "attributes": {
    "blockId": {
      "type": "string"
    },
    "slides": {
      "type": "array",
      "default": [
        {
          "id": "scd-mod-1",
          "title": "Holistic Strategy",
          "image": "scdkpi-carousel-image-holistic-strategy.png",
          "imgAlt": "Digital Strategy Planning",
          "link": "",
          "fontSize": 25,
          "textPosition": "bottom",
          "titleColor": "white",
          "filterColor": "accent",
          "backgroundColor": "white"
        },
        {
          "id": "scd-mod-2",
          "title": "Brand Evolution",
          "image": "scdkpi-carousel-image-brand-evaluation-scaled.png",
          "imgAlt": "Brand Innovation and Design",
          "link": "",
          "fontSize": 25,
          "textPosition": "bottom",
          "titleColor": "white",
          "filterColor": "accent",
          "backgroundColor": "white"
        },
        {
          "id": "scd-mod-3",
          "title": "Interface Design",
          "image": "scdkpi-carousel-image-interface-design.png",
          "imgAlt": "Sleek UX/UI Design",
          "link": "",
          "fontSize": 25,
          "textPosition": "bottom",
          "titleColor": "white",
          "filterColor": "accent",
          "backgroundColor": "white"
        },
        {
          "id": "scd-mod-4",
          "title": "Precision Marketing",
          "image": "scdkpi-carousel-image-precision-marketing-scaled.png",
          "imgAlt": "Performance Marketing Analytics",
          "link": "",
          "fontSize": 25,
          "textPosition": "bottom",
          "titleColor": "white",
          "filterColor": "accent",
          "backgroundColor": "white"
        },
        {
          "id": "scd-mod-5",
          "title": "Strategic Content",
          "image": "scdkpi-carousel-image-strategic-content.png",
          "imgAlt": "Creative Narrative and Storytelling",
          "link": "",
          "fontSize": 25,
          "textPosition": "bottom",
          "titleColor": "white",
          "filterColor": "accent",
          "backgroundColor": "white"
        }
      ]
    },
    "slideGap": {
      "type": "number",
      "default": 30
    },
    "buttonSize": {
      "type": "number",
      "default": 40
    },
    "backgroundColor": {
      "type": "string",
      "default": "transparent"
    },
    "padding": {
      "type": "object",
      "default": {
        "top": "20",
        "right": "0",
        "bottom": "20",
        "left": "0"
      }
    },
    "mobilePadding": {
      "type": "object",
      "default": {
        "top": "10",
        "right": "0",
        "bottom": "10",
        "left": "0"
      }
    },
    "title": {
      "type": "string",
      "default": "Story Craft Features"
    },
    "titleFontSize": {
      "type": "number",
      "default": 50
    },
    "titleLineHeight": {
      "type": "number",
      "default": 1
    },
    "titlePadding": {
      "type": "object",
      "default": {
        "top": "0",
        "right": "20",
        "bottom": "0",
        "left": "20"
      }
    },
    "titleAlign": {
      "type": "string",
      "default": "center"
    },
    "titleBold": {
      "type": "boolean",
      "default": true
    },
    "titleItalics": {
      "type": "boolean",
      "default": false
    },
    "titleUnderline": {
      "type": "boolean",
      "default": false
    },
    "titleColor": {
      "type": "string",
      "default": "primary"
    },
    "minSlidesToShow": {
      "type": "number",
      "default": 1.3
    },
    "slideBorderRadius": {
      "type": "object",
      "default": {
        "topLeft": 20,
        "topRight": 20,
        "bottomRight": 20,
        "bottomLeft": 20
      }
    },
    "uniteSlideSettings": {
      "type": "boolean",
      "default": true
    },
    "slideTitleFontSize": {
      "type": "number",
      "default": 25
    },
    "slideTitleColor": {
      "type": "string",
      "default": "white"
    },
    "slideFilterColor": {
      "type": "string",
      "default": "accent"
    },
    "slideBackgroundColor": {
      "type": "string",
      "default": "white"
    },
    "progressbarColor": {
      "type": "string",
      "default": "linear-gradient(90deg, secondary, primary)"
    },
    "autoScrolling": {
      "type": "boolean",
      "default": false
    },
    "scrollSpeed": {
      "type": "number",
      "default": 0.5
    },
    "progressbar": {
      "type": "boolean",
      "default": true
    }
  },
  "textdomain": "story-craft-digital-kpi",
  "editorScript": [
    "file:./index.js",
    "scdkpi-shared-libs",
    "scdkpi-tailwind",
    "scdkpi-color-palette"
  ],
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": [
    "file:./view.js",
    "scdkpi-shared-libs",
    "scdkpi-tailwind",
    "scdkpi-color-palette"
  ]
}